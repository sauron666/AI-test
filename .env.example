# ══════════════════════════════════════════════════════════════════
#  SAURON — environment configuration
#  Copy this file to `.env` and fill in the providers you will use.
# ══════════════════════════════════════════════════════════════════

# ── Core ──────────────────────────────────────────────────────────
SAURON_ENV=development
SAURON_SECRET_KEY=change-me-to-a-long-random-string
SAURON_HOST=0.0.0.0
SAURON_PORT=8000
SAURON_WEB_PORT=8080
SAURON_MCP_PORT=8765
SAURON_LOG_LEVEL=INFO

# ── Database ──────────────────────────────────────────────────────
# sqlite (default) or postgres URL
DATABASE_URL=sqlite:///./data/sauron.db

# ── LLM providers (fill in at least ONE) ──────────────────────────
# Anthropic Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-6

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Google Gemini
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.0-pro

# Ollama (local, offline brain — perfect for air-gapped engagements)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=whiterabbitneo:13b

# Default provider used by the agent router if not overridden per-session
# One of: claude | openai | gemini | ollama
DEFAULT_LLM_PROVIDER=claude

# ── Agent behaviour ───────────────────────────────────────────────
AGENT_MAX_ITERATIONS=50
AGENT_PLANNING_MODEL=claude          # which brain does high-level planning
AGENT_EXECUTION_MODEL=ollama         # which brain turns plans into commands
AGENT_REFLECTION_ENABLED=true
AGENT_AUTO_APPROVE_COMMANDS=false    # if false, operator confirms each command

# ── Tool executor sandbox ─────────────────────────────────────────
EXECUTOR_TIMEOUT_SECONDS=900
EXECUTOR_WORKDIR=/tmp/sauron-work
EXECUTOR_SCREENSHOTS=true
EXECUTOR_RECORD_PTY=true

# ── Red-team stealth defaults ─────────────────────────────────────
STEALTH_DEFAULT_PROFILE=normal       # silent | normal | aggressive
STEALTH_JITTER_MIN_MS=200
STEALTH_JITTER_MAX_MS=1500

# ── Reporting ─────────────────────────────────────────────────────
REPORT_COMPANY_NAME="Your Security Team"
REPORT_LOGO_PATH=frontend/assets/logo.svg
REPORT_OUTPUT_DIR=./reports/output

# ── Auth (single-tenant default) ──────────────────────────────────
AUTH_ENABLED=true
AUTH_DEFAULT_USER=operator
AUTH_DEFAULT_PASSWORD=change-me
